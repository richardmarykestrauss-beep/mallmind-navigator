{
  "name": "mallmind-scraper",
  "version": "2.0.0",
  "description": "SA retail price scraper for MallMind — 10 retailers, anti-blocking, Supabase upsert",
  "type": "module",
  "scripts": {
    "all":        "node --import=tsx/esm index.ts",
    "takealot":   "node --import=tsx/esm scrapers/takealot.ts",
    "checkers":   "node --import=tsx/esm scrapers/checkers.ts",
    "pnp":        "node --import=tsx/esm scrapers/pnp.ts",
    "woolworths": "node --import=tsx/esm scrapers/woolworths.ts",
    "incredible": "node --import=tsx/esm scrapers/incredible.ts",
    "game":       "node --import=tsx/esm scrapers/game.ts",
    "clicks":     "node --import=tsx/esm scrapers/clicks.ts",
    "dischem":    "node --import=tsx/esm scrapers/dischem.ts",
    "mrprice":    "node --import=tsx/esm scrapers/mrprice.ts",
    "sportsmans": "node --import=tsx/esm scrapers/sportsmans.ts",
    "malls":      "node --import=tsx/esm malls/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
