# ── MallMind Dev Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# ── Target backend ───────────────────────────────────────────────────────────
# The live Cloud Run dev service URL to smoke-test.
CLOUD_RUN_DEV_URL=https://mallmind-backend-dev-1017902775578.africa-south1.run.app

# ── Google Cloud (for Gemini report writing) ─────────────────────────────────
# Uses Application Default Credentials — run `gcloud auth application-default login`
# locally, or rely on the Compute Engine SA when running in Cloud Run.
GOOGLE_CLOUD_PROJECT=mallmind
VERTEX_AI_LOCATION=us-central1

# ── Supabase (optional — needed for /build-route smoke test) ─────────────────
# Without these, the /build-route test is marked BLOCKED.
SUPABASE_URL=https://qspsouemjtcdcfnivpnt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Report output ────────────────────────────────────────────────────────────
# Directory where smoke test reports are written.
# Relative paths are resolved from the repo root (mallmind-navigator/).
# Default: ../reports/dev-agent  (relative to google-dev-agent/)
REPORTS_DIR=../reports/dev-agent

# ── Test fixtures ────────────────────────────────────────────────────────────
# Known seeded IDs used in smoke tests. Override if your DB has different seeds.
TEST_MALL_ID=f4a2c1b3-8d7e-4f6a-9b0c-1d2e3f4a5b6c
TEST_MALL_NAME=Mall@Reds
# Coordinates must match the lat/lng stored in the malls table for this mall.
# Mall@Reds DB values: lat=-25.8537, lng=28.1878 (The Reeds, Centurion)
TEST_MALL_LAT=-25.8537
TEST_MALL_LNG=28.1878
TEST_SHOP_ID=a1b2c3d4-0001-4000-8000-100000000001
TEST_SHOP_NAME=Game
