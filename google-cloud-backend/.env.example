# ─────────────────────────────────────────────────────────────────────────────
# MallMind Cloud Run Backend — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# In production, inject these via Cloud Run environment variables
# or Secret Manager references.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (existing operational database) ─────────────────────────────────
# Use the service role key — this backend runs server-side only.
# Never expose this key to the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Option A: Gemini API key (simplest for dev/testing)
GEMINI_API_KEY=your-gemini-api-key-here

# Option B: Vertex AI (production — uses Application Default Credentials)
# Set VERTEX_PROJECT_ID and leave GEMINI_API_KEY blank to use Vertex AI.
VERTEX_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Google Cloud project ──────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud Run injects PORT=8080 automatically. Override for local dev if needed.
PORT=8080

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, restrict to your actual frontend domain.
# In development, localhost:8080 or localhost:5173 is typical.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ── IMPORTANT: what belongs here vs what doesn't ──────────────────────────────
# ✅  SUPABASE_SERVICE_ROLE_KEY — server-side only, stored in Secret Manager in production
# ✅  GEMINI_API_KEY / Anthropic key — server-side only
# ❌  VITE_* variables — those belong in the frontend .env.local only
# ❌  Service role key in frontend env — NEVER do this
# See docs/SECURITY_ENVIRONMENT_CHECKLIST.md for full guidance.
