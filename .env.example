# ─────────────────────────────────────────────────────────────────────────────
# MallMind Frontend — environment variables template
#
# Usage:
#   cp .env.example .env.local
#   Fill in the real values for your project.
#
# NEVER commit .env.local (or any .env file with real values) to version control.
# This .env.example file is safe to commit — it contains only placeholders.
#
# See docs/SECURITY_ENVIRONMENT_CHECKLIST.md for full security guidance.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (PUBLIC — safe for frontend) ────────────────────────────────────
#
# The anon key is Supabase's "publishable" key. It is intentionally public and
# safe to include in the browser bundle. Security is enforced by Row Level
# Security (RLS) policies on each table — not by keeping this key secret.
#
# NEVER put the service_role key here. The service_role key bypasses RLS and
# must only exist in backend environments (Supabase secrets, Cloud Run env).
#
# Find these values in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Cloud Run backend (OPTIONAL) ─────────────────────────────────────
#
# When set, AI queries, route building, and admin operations route to the
# Cloud Run backend instead of Supabase Edge Functions.
# Leave blank (or remove) to stay on the Supabase Edge Function path.
#
# The URL itself is public (no secrets embedded). The backend holds all
# private keys in Google Secret Manager / Cloud Run environment variables.
VITE_GOOGLE_BACKEND_URL=

# ── Web Push VAPID public key ────────────────────────────────────────────────
#
# The public half of the VAPID key pair used for Web Push subscriptions.
# This value is public — it is shared with the browser to identify your server.
# The matching VAPID PRIVATE key lives in Supabase secrets / Cloud Run env ONLY.
#
# Generate a new key pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
